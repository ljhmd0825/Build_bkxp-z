FROM ubuntu:20.04

# 0. 환경 변수 설정 (인터랙티브 방지 및 패키지 경로)
ENV DEBIAN_FRONTEND=noninteractive
ENV PKG_CONFIG_LIBDIR=/usr/lib/aarch64-linux-gnu/pkgconfig
ENV PKG_CONFIG_PATH=/usr/lib/aarch64-linux-gnu/pkgconfig

# 1. 수정된 패키지 설치 부분
RUN dpkg --add-architecture arm64 && \
    sed -i 's/^deb http/deb [arch=amd64] http/g' /etc/apt/sources.list && \
    echo "deb [arch=arm64] http://ports.ubuntu.com/ubuntu-ports focal main restricted universe multiverse" >> /etc/apt/sources.list && \
    echo "deb [arch=arm64] http://ports.ubuntu.com/ubuntu-ports focal-updates main restricted universe multiverse" >> /etc/apt/sources.list && \
    echo "deb [arch=arm64] http://ports.ubuntu.com/ubuntu-ports focal-security main restricted universe multiverse" >> /etc/apt/sources.list && \
    apt-get update && \
    apt-get install -y --no-install-recommends \
    build-essential gcc-aarch64-linux-gnu g++-aarch64-linux-gnu pkg-config \
    # [수정] libtool과 automake 추가
    libtool automake \
    git wget ca-certificates bison xxd python3-pip gettext \
    ruby ruby-dev \
    zlib1g-dev:arm64 libexpat1-dev:arm64 libssl-dev:arm64 \
    libglib2.0-dev:arm64 libpixman-1-dev:arm64 && \
    rm -rf /var/lib/apt/lists/*

# 2. CMake 최신화 (3.26.4) - 20.04 기본 3.16 버전 탈피용
RUN wget https://github.com/Kitware/CMake/releases/download/v3.26.4/cmake-3.26.4-linux-x86_64.sh && \
    chmod +x cmake-3.26.4-linux-x86_64.sh && \
    ./cmake-3.26.4-linux-x86_64.sh --skip-license --prefix=/usr && \
    rm cmake-3.26.4-linux-x86_64.sh

# 3. Autoconf 최신화 (2.71) - Ruby나 SDL2 구형 매크로 에러 방지용
RUN wget http://ftp.gnu.org/gnu/autoconf/autoconf-2.71.tar.gz && \
    tar -xzf autoconf-2.71.tar.gz && \
    cd autoconf-2.71 && ./configure --prefix=/usr && make -j$(nproc) && make install && \
    cd .. && rm -rf autoconf-2.71*

# 4. Meson & Ninja 설치 (pip3)
RUN pip3 install --upgrade pip && \
    pip3 install meson ninja

# 5. Meson 크로스 빌드 툴체인 파일 생성
# GitHub Actions 실행 시 이 파일을 참조하여 빌드하면 아주 깔끔함
RUN printf "[binaries]\n\
c = 'aarch64-linux-gnu-gcc'\n\
cpp = 'aarch64-linux-gnu-g++'\n\
ar = 'aarch64-linux-gnu-ar'\n\
strip = 'aarch64-linux-gnu-strip'\n\
pkgconfig = 'pkg-config'\n\n\
[host_machine]\n\
system = 'linux'\n\
cpu_family = 'aarch64'\n\
cpu = 'armv8-a'\n\
endian = 'little'\n\n\
[properties]\n\
pkg_config_libdir = '/usr/lib/aarch64-linux-gnu/pkgconfig'\n" > /usr/local/share/aarch64-cross.txt

WORKDIR /workspace
