FROM ubuntu:20.04

ENV DEBIAN_FRONTEND=noninteractive

# 1. 멀티 아키텍처 및 기본 패키지 설치
RUN dpkg --add-architecture arm64 && \
    sed -i 's/^deb http/deb [arch=amd64] http/g' /etc/apt/sources.list && \
    echo "deb [arch=arm64] http://ports.ubuntu.com/ubuntu-ports focal main restricted universe multiverse" >> /etc/apt/sources.list && \
    echo "deb [arch=arm64] http://ports.ubuntu.com/ubuntu-ports focal-updates main restricted universe multiverse" >> /etc/apt/sources.list && \
    apt-get update && \
    apt-get install -y --no-install-recommends \
    build-essential gcc-aarch64-linux-gnu g++-aarch64-linux-gnu pkg-config \
    git ca-certificates python3 python3-pip python3-setuptools python3-wheel \
    wget ccache cmake autoconf automake premake4 clang p7zip-full \
    mercurial libarchive-dev libuv1-dev \
    # 타겟(arm64) 라이브러리들
    libsdl2-dev:arm64 libsdl2-net-dev:arm64 libasound2-dev:arm64 \
    libfreetype6-dev:arm64 libgles2-mesa-dev:arm64 libegl1-mesa-dev:arm64 \
    libdrm-dev:arm64 libgbm-dev:arm64 libglew-dev:arm64 libjpeg-dev:arm64 \
    libgif-dev:arm64 libfribidi-dev:arm64 libtheora-dev:arm64 libmpeg2-4-dev:arm64 \
    libfaad-dev:arm64 libvpx-dev:arm64 libtiff-dev:arm64 libpng-dev:arm64 \
    liba52-0.7.4-dev:arm64 libcurl4-openssl-dev:arm64 zlib1g-dev:arm64 \
    libmad0-dev:arm64 libogg-dev:arm64 libvorbis-dev:arm64 libflac-dev:arm64 \
    libopenal-dev:arm64 libmikmod-dev:arm64 libglib2.0-dev:arm64 \
    libevdev-dev:arm64 libexpat1-dev:arm64 libreadline-dev:arm64 \
    libncurses5-dev:arm64 libncursesw5-dev:arm64 libslang2-dev:arm64 \
    libspeechd-dev:arm64 libopenmpt-dev:arm64 && \
    rm -rf /var/lib/apt/lists/*

# 2. [핵심] Meson & Ninja 최신 버전 설치 및 경로 링크
# Ubuntu 20.04 기본 meson은 너무 낮아 수동 설치가 필수입니다.
RUN pip3 install --upgrade pip && \
    pip3 install meson ninja && \
    ln -sf /usr/local/bin/meson /usr/bin/meson && \
    ln -sf /usr/local/bin/ninja /usr/bin/ninja

# 3. CMake 툴체인 설정 (기존과 동일)
RUN printf 'set(CMAKE_SYSTEM_NAME Linux)\nset(CMAKE_SYSTEM_PROCESSOR aarch64)\nset(CMAKE_C_COMPILER aarch64-linux-gnu-gcc)\nset(CMAKE_CXX_COMPILER aarch64-linux-gnu-g++)\nset(CMAKE_FIND_ROOT_PATH /usr/aarch64-linux-gnu /usr/lib/aarch64-linux-gnu /usr)\nset(CMAKE_FIND_ROOT_PATH_MODE_PROGRAM NEVER)\nset(CMAKE_FIND_ROOT_PATH_MODE_LIBRARY BOTH)\nset(CMAKE_FIND_ROOT_PATH_MODE_INCLUDE BOTH)\nset(CMAKE_FIND_ROOT_PATH_MODE_PACKAGE BOTH)\nset(PKG_CONFIG_EXECUTABLE /usr/bin/pkg-config)\nset(ENV{PKG_CONFIG_PATH} "/usr/lib/aarch64-linux-gnu/pkgconfig")\nset(ENV{PKG_CONFIG_LIBDIR} "/usr/lib/aarch64-linux-gnu/pkgconfig")\n' > /tmp/aarch64-toolchain.cmake

# 4. SDL2 & SDL_net & Fluidsynth 커스텀 빌드 (기존과 동일)
# ... (사용자님이 작성하신 SDL2, SDL_net, Fluidsynth RUN 문 그대로 유지) ...

# 5. [수정] 루비 크로스 빌드 (호스트용 루비 설치 추가)
RUN apt-get update && apt-get install -y ruby-full && \
    cd /tmp && \
    wget https://cache.ruby-lang.org/pub/ruby/3.1/ruby-3.1.2.tar.gz && \
    tar -xzf ruby-3.1.2.tar.gz && cd ruby-3.1.2 && \
    # --with-baseruby 옵션을 추가하여 호스트의 루비를 사용하도록 명시합니다.
    ./configure --host=aarch64-linux-gnu \
                --prefix=/usr \
                --libdir=/usr/lib/aarch64-linux-gnu \
                --with-baseruby=/usr/bin/ruby \
                --with-static-linked-ext \
                --disable-install-doc && \
    make -j$(nproc) && make install && \
    cd .. && rm -rf ruby-3.1.2*

COPY build-64.sh /build-64.sh
RUN chmod +x /build-64.sh
COPY patches/ /patches/

WORKDIR /build
ENTRYPOINT ["/build-64.sh"]
